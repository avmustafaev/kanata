(defcfg
  linux-dev-names-include (
    "Telink Wireless Device"
    "Telink Wireless Device Consumer Control"
  )
  process-unmapped-keys yes
)

(defsrc
  kp0
  kp1
  kp2
  kp3
  kp4
  kp5
  kp6
  kp7
  kp8
  kp9
  lshift
  lmet
  f23
  calc
)

(deflayer default
  A-0
  A-1
  A-2
  A-3
  A-4
  A-5
  A-6
  A-7
  A-8
  A-9
  lshift   ;; Shift оставляем как есть
  lalt     ;; Super превращаем в Alt (это и есть ваш $mod)
  s  
  A-m    ;; F23 превращаем в Shift+S
)